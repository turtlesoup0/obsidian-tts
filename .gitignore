# ===========================================
# obsidian-tts .gitignore
# ===========================================

# Node.js
node_modules/
dist/
*.tsbuildinfo

# Azure Functions
local.settings.json
bin/
obj/
.vs/

# Python
.venv/
venv/
__pycache__/
*.pyc

# Environment & Secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor / manual backups
*.bak
*.broken-*

# IDE
.vscode/
.idea/
*.swp
*~

# ===========================================
# Project-specific
# ===========================================

# TTS proxy data (runtime cache)
docker/tts-proxy/data/

# Obsidian vault config (user-specific)
.obsidian/

# MoAI framework (removed)
.moai/
.moai-backups/
.claude/agents/moai/
.claude/hooks/moai/
.claude/skills/moai/
.claude/skills/moai-*/
.claude/rules/moai/

# Claude worktrees
.claude/worktrees/
.claude/plans/

# Misc
obsidian-tts-config.md
*.log
logs/
.vercel
